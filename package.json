{
  "name": "vibescan",
  "version": "0.1.0",
  "description": "VibeScan - Dual-scanner vulnerability scanning SaaS platform",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "migrate:rollback": "node dist/migrate.js rollback",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test test/e2e",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' --fix"
  },
  "dependencies": {
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger-ui": "^5.2.5",
    "ajv": "8.18.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.4",
    "fastify-swagger": "^5.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@playwright/test": "^1.59.1",
    "@types/bcrypt": "^5.0.2",
    "@types/crypto-js": "^4.2.2",
    "@types/fastify-cors": "^2.1.2",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cypress": "^15.13.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prom-client": "^15.1.3",
    "stripe": "^22.0.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
