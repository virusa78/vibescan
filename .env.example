# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vibescan
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS/S3 Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_SOURCES=vibescan-sources
S3_BUCKET_SBOMS=vibescan-sboms
S3_BUCKET_PDFS=vibescan-pdfs

# Application Configuration
NODE_ENV=development
PORT=3001
# ENCRYPTION_KEY must be exactly 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT Configuration
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Scanning Configuration
GRYPE_IMAGE=anchore/grype:latest
MAX_SOURCE_SIZE_MB=50
CVE_UPDATE_INTERVAL_HOURS=6
REMOTE_SCANNER_ENABLED=false
REMOTE_SCANNER_API_URL=
REMOTE_SCANNER_API_KEY=
REMOTE_SCANNER_PROVIDER_ID=grype_like

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# OpenSaaS migration boundary controls (safe default: disabled)
OPENSAAS_MODE=false
# Comma-separated: auth,api_keys,billing,settings (core_workflow remains backend-owned in this cutover)
OPENSAAS_PLATFORM_OWNED=

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_FREE=price_free_trial
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise

# GitHub App Webhook Configuration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_API_BASE_URL=https://api.github.com

# Frontend URL (for redirect URLs)
FRONTEND_URL=http://localhost:3000
