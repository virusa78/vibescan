datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums
enum ScanStatus {
  pending
  scanning
  done
  error
  cancelled
}

enum ScanSource {
  grype
  codescoring_johnny
  snyk
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  exhausted
}

enum RemediationPromptStatus {
  accepted
  rejected_quota
  failed_provider
  completed
}

enum VulnAcceptanceStatus {
  accepted
  revoked
  expired
}

enum CycloneDxRolloutStage {
  shadow_smoke
  canary_cutover_cohort
  expand_cohort
  ready_for_prod
}

enum CycloneDxRolloutStatus {
  in_progress
  blocked
  ready_for_prod
  rollback_active
}

enum PlanTier {
  free_trial
  starter
  pro
  enterprise
}

enum OrganizationRole {
  owner
  admin
  member
}

enum TeamRole {
  maintainer
  member
}

enum WorkspaceRole {
  admin
  member
  viewer
}

// Core User model - VibeScan schema
model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Auth fields
  email        String  @unique
  username     String? @unique
  passwordHash String? @map("password_hash")

  // Profile fields
  displayName         String? @map("display_name")
  isAdmin             Boolean @default(false)
  snykApiKeyEncrypted Bytes?  @map("snyk_api_key_encrypted")

  // Billing fields
  plan                 PlanTier @default(free_trial)
  stripeCustomerId     String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  subscriptionStatus   String?  @map("subscription_status") // 'active', 'canceled', 'past_due'

  // Regional settings
  region            String  @default("OTHER") // IN, PK, OTHER
  timezone          String?
  language          String? @default("en")
  uiPreferences     Json    @default("{}") @map("ui_preferences")
  activeWorkspaceId String? @map("active_workspace_id") @db.Uuid

  // Quota tracking
  monthlyQuotaLimit Int      @default(10) @map("monthly_quota_limit")
  monthlyQuotaUsed  Int      @default(0) @map("monthly_quota_used")
  quotaResetDate    DateTime @default(now()) @map("quota_reset_date")

  // Relations
  apiKeys                     ApiKey[]
  scans                       Scan[]
  webhooks                    Webhook[]
  vulnAcceptances             VulnAcceptance[]
  aiFixPrompts                AiFixPrompt[]
  policyOverride              UserPolicyOverride?
  remediationPromptUsages     RemediationPromptUsage[]
  findings                    Finding[]
  ownedOrganizations          Organization[]               @relation("OrganizationOwner")
  organizationMemberships     OrganizationMembership[]
  teamMemberships             TeamMembership[]
  workspaceMemberships        WorkspaceMembership[]
  createdWorkspaces           Workspace[]                  @relation("WorkspaceCreatedBy")
  activeWorkspace             Workspace?                   @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  quotaLedger                 QuotaLedger[]
  projectNotificationSettings ProjectNotificationSetting[]

  @@index([activeWorkspaceId])
  @@map("users")
}

// Organizations for team/enterprise plans
model Organization {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name        String
  slug        String  @unique
  ownerUserId String  @map("owner_user_id") @db.Uuid
  isPersonal  Boolean @default(false) @map("is_personal")

  owner       User                     @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberships OrganizationMembership[]
  teams       Team[]
  workspaces  Workspace[]

  @@index([ownerUserId])
  @@map("organizations")
}

model OrganizationMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(member)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId], map: "organization_memberships_unique")
  @@index([userId], map: "organization_memberships_user_id_idx")
  @@map("organization_memberships")
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationId String  @map("organization_id") @db.Uuid
  name           String
  slug           String
  isDefault      Boolean @default(false) @map("is_default")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships  TeamMembership[]
  workspaces   Workspace[]

  @@unique([organizationId, slug], map: "teams_organization_slug_unique")
  @@index([organizationId], map: "teams_organization_id_idx")
  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  teamId String   @map("team_id") @db.Uuid
  userId String   @map("user_id") @db.Uuid
  role   TeamRole @default(member)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId], map: "team_memberships_unique")
  @@index([userId], map: "team_memberships_user_id_idx")
  @@map("team_memberships")
}

model Workspace {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizationId  String  @map("organization_id") @db.Uuid
  teamId          String? @map("team_id") @db.Uuid
  name            String
  slug            String
  isPersonal      Boolean @default(false) @map("is_personal")
  createdByUserId String  @map("created_by_user_id") @db.Uuid

  organization                Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team                        Team?                        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdByUser               User                         @relation("WorkspaceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  members                     WorkspaceMembership[]
  activeUsers                 User[]                       @relation("ActiveWorkspace")
  scans                       Scan[]
  apiKeys                     ApiKey[]
  webhooks                    Webhook[]
  projectNotificationSettings ProjectNotificationSetting[]
  githubInstallations         GithubInstallation[]
  quotaLedger                 QuotaLedger[]

  @@unique([organizationId, slug], map: "workspaces_organization_slug_unique")
  @@index([organizationId], map: "workspaces_organization_id_idx")
  @@index([teamId], map: "workspaces_team_id_idx")
  @@index([createdByUserId], map: "workspaces_created_by_user_id_idx")
  @@map("workspaces")
}

model WorkspaceMembership {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(member)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId], map: "workspace_memberships_unique")
  @@index([userId], map: "workspace_memberships_user_id_idx")
  @@map("workspace_memberships")
}

// API Keys for CI/CD integration
model ApiKey {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  userId      String    @map("user_id") @db.Uuid
  workspaceId String?   @map("workspace_id") @db.Uuid
  name        String
  keyPrefix   String?   @map("key_prefix")
  keyHash     String    @map("key_hash")
  lastUsedAt  DateTime? @map("last_used_at")
  enabled     Boolean   @default(true)

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  usageEvents ApiKeyUsageEvent[]

  @@unique([userId, keyHash])
  @@index([workspaceId])
  @@index([keyPrefix])
  @@map("api_keys")
}

model ApiKeyUsageEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  apiKeyId  String   @map("api_key_id") @db.Uuid

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_key_usage_events")
}

model ProjectNotificationSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  userId               String   @map("user_id") @db.Uuid
  workspaceId          String?  @map("workspace_id") @db.Uuid
  projectKey           String   @map("project_key")
  emailOnScanComplete  Boolean  @default(true) @map("email_on_scan_complete")
  emailOnVulnerability Boolean  @default(true) @map("email_on_vulnerability")
  weeklyDigest         Boolean  @default(false) @map("weekly_digest")
  smsEnabled           Boolean  @default(false) @map("sms_enabled")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, projectKey], map: "idx_project_notification_unique")
  @@index([workspaceId], map: "project_notification_settings_workspace_id_idx")
  @@index([userId], map: "project_notification_settings_user_id_idx")
  @@map("project_notification_settings")
}

// Scans - core entity
model Scan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  userId      String  @map("user_id") @db.Uuid
  orgId       String? @map("org_id") @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid

  // Input details
  inputType     String @map("input_type") // 'source_zip', 'sbom_upload', 'github_app', 'ci_plugin'
  inputRef      String @map("input_ref") // filename, SBOM URL, GitHub ref, etc.
  githubContext Json?  @map("github_context")

  // SBOM and components
  sbomRaw    Json? @map("sbom_raw")
  components Json  @default("[]")

  // Scan status and plan at submission time
  status           ScanStatus   @default(pending)
  planAtSubmission String       @default("free_trial") @map("plan_at_submission") // free_trial, starter, pro, enterprise
  plannedSources   ScanSource[] @default([]) @map("planned_sources")
  errorMessage     String?      @map("error_message")

  // Relations
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace               Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  scanResults             ScanResult[]
  findings                Finding[]
  scanDeltas              ScanDelta[]
  aiFixPrompts            AiFixPrompt[]
  remediationPromptUsages RemediationPromptUsage[]
  securityScores          SecurityScore[]
  vulnAcceptances         VulnAcceptance[]
  webhookDeliveries       WebhookDelivery[]

  @@index([workspaceId])
  @@map("scans")
}

// Scanner output results (provider-aligned)
model ScanResult {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  scanId String     @map("scan_id") @db.Uuid
  source ScanSource

  rawOutput       Json     @map("raw_output")
  vulnerabilities Json
  scannerVersion  String   @map("scanner_version")
  cveDbTimestamp  DateTime @map("cve_db_timestamp")
  durationMs      Int      @map("duration_ms")

  scan                     Scan                      @relation(fields: [scanId], references: [id], onDelete: Cascade)
  CycloneDxRolloutSnapshot CycloneDxRolloutSnapshot?

  @@unique([scanId, source], map: "idx_scan_results_unique")
  @@map("scan_results")
}

// Individual vulnerability findings with fingerprint-based deduplication
model Finding {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scanId String @map("scan_id") @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Fingerprint for deduplication across scans
  fingerprint String // HASH(cve_id + package_name + installed_version + file_path)

  // Finding details (immutable except severity/fixed_version which can update from CVE DB)
  cveId            String  @map("cve_id")
  packageName      String  @map("package_name")
  installedVersion String  @map("installed_version")
  filePath         String? @map("file_path")

  // Severity and fix info (can change if CVE DB updates)
  severity     String // CRITICAL, HIGH, MEDIUM, LOW, INFO
  cvssScore    Decimal? @map("cvss_score") @db.Decimal(3, 1)
  fixedVersion String?  @map("fixed_version")

  // Status tracking
  status            String    @default("active") // active, mitigated
  mitigatedAt       DateTime? @map("mitigated_at")
  mitigatedInScanId String?   @map("mitigated_in_scan_id") @db.Uuid

  // Source scanner
  source ScanSource // grype, codescoring_johnny, snyk

  // Description and details (updated at import time)
  description  String?
  detectedData Json?   @map("detected_data")

  // Relations
  scan                   Scan                     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user                   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  history                FindingHistory[]
  RemediationPromptUsage RemediationPromptUsage[]

  @@unique([scanId, fingerprint], map: "idx_finding_unique_per_scan")
  @@index([fingerprint])
  @@index([userId, status])
  @@index([scanId])
  @@index([cveId])
  @@map("findings")
}

// Audit trail for finding status changes
model FindingHistory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  findingId String @map("finding_id") @db.Uuid

  // Event type: severity_changed, auto_mitigated, manually_accepted, etc.
  event String

  // Previous and new values for the event
  prevValue String? @map("prev_value")
  newValue  String? @map("new_value")

  // Optional additional context
  metadata Json?

  // Relation
  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([findingId])
  @@index([event])
  @@map("finding_history")
}

// Delta comparison (enterprise vs free)
model ScanDelta {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  scanId String @unique @map("scan_id") @db.Uuid

  totalFreeCount       Int     @default(0) @map("total_free_count")
  totalEnterpriseCount Int     @default(0) @map("total_enterprise_count")
  deltaCount           Int     @default(0) @map("delta_count")
  deltaBySeverity      Json    @map("delta_by_severity")
  deltaVulnerabilities Json?   @map("delta_vulnerabilities")
  isLocked             Boolean @default(false) @map("is_locked")

  // Reimport summary from fingerprint-based deduplication
  // { new_count, mitigated_count, updated_count, unchanged_count }
  reimportSummary Json? @map("reimport_summary")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("scan_deltas")
}

// Regional policy configuration
model RegionPolicy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  regionCode                    String  @unique @map("region_code")
  monthlyScanLimit              Int     @map("monthly_scan_limit")
  monthlyRemediationPromptLimit Int     @map("monthly_remediation_prompt_limit")
  maxPromptsPerFinding          Int     @default(3) @map("max_prompts_per_finding")
  isActive                      Boolean @default(true) @map("is_active")
  updatedByUserId               String? @map("updated_by_user_id") @db.Uuid

  @@map("region_policies")
}

// Per-user overrides for regional policy
model UserPolicyOverride {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId                        String  @unique @map("user_id") @db.Uuid
  monthlyScanLimit              Int?    @map("monthly_scan_limit")
  monthlyRemediationPromptLimit Int?    @map("monthly_remediation_prompt_limit")
  maxPromptsPerFinding          Int?    @map("max_prompts_per_finding")
  reason                        String?
  updatedByUserId               String? @map("updated_by_user_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_policy_overrides")
}

// Remediation prompt usage ledger
model RemediationPromptUsage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId         String                  @map("user_id") @db.Uuid
  scanId         String                  @map("scan_id") @db.Uuid
  findingId      String                  @map("finding_id") @db.Uuid
  regionAtCall   String                  @map("region_at_call")
  policySnapshot Json                    @map("policy_snapshot")
  requestKey     String                  @default(dbgenerated("gen_random_uuid()")) @map("request_key")
  promptType     String                  @map("prompt_type")
  provider       String
  status         RemediationPromptStatus @default(accepted)
  tokensIn       Int                     @default(0) @map("tokens_in")
  tokensOut      Int                     @default(0) @map("tokens_out")
  costEstimate   Decimal?                @map("cost_estimate") @db.Decimal(10, 4)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scan    Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)
  finding Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@unique([userId, requestKey])
  @@index([scanId])
  @@index([findingId])
  @@map("remediation_prompt_usages")
}

// AI fix prompt suggestions
model AiFixPrompt {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scanId          String @map("scan_id") @db.Uuid
  userId          String @map("user_id") @db.Uuid
  vulnerabilityId String @map("vulnerability_id")
  requestKey      String @default(dbgenerated("gen_random_uuid()")) @map("request_key")

  promptText      String  @map("prompt_text")
  promptType      String  @default("patch") @map("prompt_type")
  provider        String  @default("local")
  modelName       String? @map("model_name")
  responsePayload Json?   @map("response_payload")
  status          String  @default("generated")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, requestKey])
  @@map("ai_fix_prompts")
}

// Security score for scans
model SecurityScore {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  scanId    String  @unique @map("scan_id") @db.Uuid
  score     Decimal @db.Decimal(5, 2)
  grade     String
  breakdown Json

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("security_scores")
}

// Vulnerability acceptance/waiver
model VulnAcceptance {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scanId          String @map("scan_id") @db.Uuid
  userId          String @map("user_id") @db.Uuid
  vulnerabilityId String @map("vulnerability_id")

  reason    String?
  status    VulnAcceptanceStatus @default(accepted)
  expiresAt DateTime?            @map("expires_at")

  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([scanId, userId, vulnerabilityId])
  @@map("vuln_acceptances")
}

// GitHub app installations
model GithubInstallation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  orgId                String? @map("org_id") @db.Uuid
  workspaceId          String? @map("workspace_id") @db.Uuid
  githubInstallationId BigInt  @map("github_installation_id")
  githubAppId          String  @map("github_app_id")
  accountLogin         String? @map("account_login")
  accountType          String? @map("account_type")
  repositorySelection  String  @default("all") @map("repository_selection")

  reposScope       String[] @default([]) @map("repos_scope")
  triggerOnPush    Boolean  @default(true) @map("trigger_on_push")
  triggerOnPr      Boolean  @default(true) @map("trigger_on_pr")
  targetBranches   String[] @default(["main", "develop"]) @map("target_branches")
  failPrOnSeverity String   @default("CRITICAL") @map("fail_pr_on_severity")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([githubInstallationId])
  @@index([workspaceId])
  @@map("github_installations")
}

// Webhooks for scan notifications
model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId                 String   @map("user_id") @db.Uuid
  workspaceId            String?  @map("workspace_id") @db.Uuid
  url                    String
  events                 String[] @default(["scan_complete"]) // JSON array of event types
  signingSecretEncrypted Bytes    @map("signing_secret_encrypted")
  enabled                Boolean  @default(true)

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
  @@map("webhooks")
}

// Webhook delivery history
model WebhookDelivery {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  webhookId String @map("webhook_id") @db.Uuid
  scanId    String @map("scan_id") @db.Uuid

  eventType       String                @default("scan_complete") @map("event_type")
  payload         Json?
  targetUrl       String                @map("target_url")
  payloadHash     String                @map("payload_hash")
  attemptNumber   Int                   @default(1) @map("attempt_number")
  httpStatus      Int?                  @map("http_status")
  responseBody    String?               @map("response_body")
  durationMs      Int?                  @map("duration_ms")
  deliveredAt     DateTime?             @map("delivered_at")
  nextRetryAt     DateTime?             @map("next_retry_at")
  manualRetryOfId String?               @map("manual_retry_of_id") @db.Uuid
  status          WebhookDeliveryStatus @default(pending)

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  scan    Scan    @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@map("webhook_deliveries")
}

// Quota ledger for audit trail and tracking quota consumption
model QuotaLedger {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  userId      String  @map("user_id") @db.Uuid
  workspaceId String? @map("workspace_id") @db.Uuid

  // Action type: scan_submitted, scan_refunded, monthly_reset
  action String

  // Amount of quota consumed/refunded
  amount Int

  // Reason for the action
  reason String?

  // Balance before and after for audit trail
  balanceBefore Int @map("balance_before")
  balanceAfter  Int @map("balance_after")

  // Reference to related scan if applicable
  relatedScanId String? @map("related_scan_id") @db.Uuid

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@map("quota_ledger")
}

model CycloneDxRolloutSnapshot {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  scannerId      String                 @map("scanner_id")
  scanResultId   String                 @unique @map("scan_result_id") @db.Uuid
  rolloutStage   CycloneDxRolloutStage  @map("rollout_stage")
  progressStatus CycloneDxRolloutStatus @map("progress_status")
  decisionStatus String                 @map("decision_status")
  gateStatus     String                 @map("gate_status")
  gateSnapshot   Json                   @map("gate_snapshot")
  ingestionMeta  Json                   @map("ingestion_meta")
  summary        Json                   @map("summary")

  scanResult            ScanResult             @relation(fields: [scanResultId], references: [id], onDelete: Cascade)
  CycloneDxRolloutState CycloneDxRolloutState?

  @@index([scannerId, createdAt])
  @@index([rolloutStage, progressStatus])
  @@map("cyclonedx_rollout_snapshots")
}

model CycloneDxRolloutState {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  scannerId        String                 @unique @map("scanner_id")
  currentStage     CycloneDxRolloutStage  @default(shadow_smoke) @map("current_stage")
  progressStatus   CycloneDxRolloutStatus @default(in_progress) @map("progress_status")
  latestSnapshotId String?                @unique @map("latest_snapshot_id") @db.Uuid
  latestDecision   Json?                  @map("latest_decision")

  latestSnapshot CycloneDxRolloutSnapshot? @relation(fields: [latestSnapshotId], references: [id], onDelete: SetNull)

  @@map("cyclonedx_rollout_states")
}
