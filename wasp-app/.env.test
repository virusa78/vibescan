# .env.test — Test environment for Jest / integration tests
# Auto-loaded when running: npm test

PORT=3556
WASP_SERVER_URL=http://localhost:3556
WASP_WEB_CLIENT_URL=http://localhost:3000

# Test database (isolated, clean per run)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibescan_test

# Payments (dev mocks)
PAYMENTS_HOBBY_SUBSCRIPTION_PLAN_ID=test_hobby_plan
PAYMENTS_PRO_SUBSCRIPTION_PLAN_ID=test_pro_plan
PAYMENTS_CREDITS_10_PLAN_ID=test_credits_plan

# Stripe (test mode)
STRIPE_API_KEY=sk_test_YOUR_TEST_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_SECRET_HERE

# LemonSqueezy (disabled in tests)
LEMONSQUEEZY_API_KEY=test_lsq_key
LEMONSQUEEZY_STORE_ID=123456
LEMONSQUEEZY_WEBHOOK_SECRET=test_lsq_webhook_secret

# Polar (disabled in tests)
POLAR_ORGANIZATION_ACCESS_TOKEN=test_polar_token
POLAR_WEBHOOK_SECRET=test_polar_webhook_secret
POLAR_SANDBOX_MODE=true

# OpenAI (mocked in tests)
OPENAI_API_KEY=sk-test-mock-key

# S3 / MinIO (test bucket)
AWS_S3_REGION=us-east-1
AWS_S3_IAM_ACCESS_KEY=minioadmin
AWS_S3_IAM_SECRET_KEY=minioadmin
AWS_S3_FILES_BUCKET=vibescan-test-sources
AWS_S3_ENDPOINT=http://127.0.0.1:9001
AWS_S3_FORCE_PATH_STYLE=true

# Plausible (disabled in tests)
PLAUSIBLE_API_KEY=test_plausible_key
PLAUSIBLE_SITE_ID=test.local
PLAUSIBLE_BASE_URL=https://plausible.io/api

# Google Analytics (disabled in tests)
GOOGLE_ANALYTICS_CLIENT_EMAIL=test@example.com
GOOGLE_ANALYTICS_PRIVATE_KEY=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0tCg==
GOOGLE_ANALYTICS_PROPERTY_ID=000000000

# SendGrid (disabled in tests)
SENDGRID_API_KEY=SG.test.sendgrid.key
SKIP_EMAIL_VERIFICATION_IN_DEV=true

# Admin emails
ADMIN_EMAILS=admin@test.example.com

# JWT & Encryption (test keys)
JWT_SECRET=test-jwt-secret-key-do-not-use-in-production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Test-specific flags
NODE_ENV=test
WASP_ENV=test
