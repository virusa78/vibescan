# .env.ci — CI environment for GitHub Actions / automated builds
# Clean, minimal config for CI pipelines

PORT=3557
WASP_SERVER_URL=http://localhost:3557
WASP_WEB_CLIENT_URL=http://localhost:3000

# CI database (ephemeral, provided by CI infra)
DATABASE_URL=${DATABASE_URL:-postgresql://postgres:postgres@localhost:5432/vibescan_ci}

# Payments (dummy)
PAYMENTS_HOBBY_SUBSCRIPTION_PLAN_ID=ci_hobby_plan
PAYMENTS_PRO_SUBSCRIPTION_PLAN_ID=ci_pro_plan
PAYMENTS_CREDITS_10_PLAN_ID=ci_credits_plan

# Stripe (test keys, no real calls)
STRIPE_API_KEY=sk_test_YOUR_CI_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_ci_YOUR_SECRET_HERE

# LemonSqueezy (disabled)
LEMONSQUEEZY_API_KEY=ci_lsq_key
LEMONSQUEEZY_STORE_ID=000000
LEMONSQUEEZY_WEBHOOK_SECRET=ci_lsq_webhook_secret

# Polar (disabled)
POLAR_ORGANIZATION_ACCESS_TOKEN=ci_polar_token
POLAR_WEBHOOK_SECRET=ci_polar_webhook_secret
POLAR_SANDBOX_MODE=true

# OpenAI (disabled)
OPENAI_API_KEY=sk-ci-mock-key

# S3 / MinIO (disabled, use local mock)
AWS_S3_REGION=us-east-1
AWS_S3_IAM_ACCESS_KEY=minioadmin
AWS_S3_IAM_SECRET_KEY=minioadmin
AWS_S3_FILES_BUCKET=vibescan-ci-sources
AWS_S3_ENDPOINT=http://127.0.0.1:9002
AWS_S3_FORCE_PATH_STYLE=true

# Analytics (disabled)
PLAUSIBLE_API_KEY=ci_plausible_key
PLAUSIBLE_SITE_ID=ci.local
PLAUSIBLE_BASE_URL=https://plausible.io/api

# Google Analytics (disabled)
GOOGLE_ANALYTICS_CLIENT_EMAIL=ci@example.com
GOOGLE_ANALYTICS_PRIVATE_KEY=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0tCg==
GOOGLE_ANALYTICS_PROPERTY_ID=000000000

# Email (disabled)
SENDGRID_API_KEY=SG.ci.sendgrid.key
SKIP_EMAIL_VERIFICATION_IN_DEV=true

# Admin
ADMIN_EMAILS=ci@example.com

# JWT & Encryption (CI keys)
JWT_SECRET=ci-jwt-secret-key-do-not-use-elsewhere
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CI-specific flags
NODE_ENV=ci
WASP_ENV=ci
CI=true
